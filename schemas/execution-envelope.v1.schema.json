{
  "$defs": {
    "rlens_context_ref": {
      "additionalProperties": false,
      "properties": {
        "bundle_commit": {
          "pattern": "^[0-9a-f]{40}$",
          "type": [
            "string",
            "null"
          ]
        },
        "does_not_establish": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "freshness_status": {
          "enum": [
            "fresh_exact",
            "fresh_dirty_unverified",
            "stale_head",
            "unknown",
            "not_required"
          ]
        },
        "generated_at": {
          "format": "date-time",
          "type": "string"
        },
        "live_commit_at_claim": {
          "pattern": "^[0-9a-f]{40}$",
          "type": [
            "string",
            "null"
          ]
        },
        "manifest_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "preflight_status": {
          "enum": [
            "pass",
            "warn",
            "fail",
            "not_applicable",
            "unknown"
          ]
        },
        "repo": {
          "pattern": "^[A-Za-z0-9_.-]{1,120}$",
          "type": "string"
        },
        "schema_version": {
          "const": 1
        },
        "source": {
          "minLength": 1,
          "type": "string"
        },
        "stem": {
          "pattern": "^[A-Za-z0-9_.-]{1,160}$",
          "type": "string"
        },
        "task_profile": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "repo",
        "stem",
        "manifest_sha256",
        "freshness_status",
        "task_profile",
        "preflight_status"
      ],
      "type": "object"
    },
    "rlens_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "opportunistic",
            "required",
            "strict",
            "live-first",
            "external-safe"
          ]
        },
        "task_profile": {
          "type": "string",
          "minLength": 1
        },
        "skip_reason": {
          "type": "string",
          "enum": [
            "not_required",
            "live_first_primary",
            "context_pack_unavailable",
            "stale_context_explicitly_allowed",
            "external_safe_export_blocked",
            "trivial_task",
            "not_yet_generated",
            "policy_override"
          ]
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "mode"
      ]
    },
    "rlens_policy_evaluation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "opportunistic",
            "required",
            "strict",
            "live-first",
            "external-safe"
          ]
        },
        "requires_context": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "satisfied",
            "skipped",
            "blocked",
            "not_required"
          ]
        },
        "task_profile": {
          "type": [
            "string",
            "null"
          ]
        },
        "has_context_ref": {
          "type": "boolean"
        },
        "skip_reason": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "not_required",
            "live_first_primary",
            "context_pack_unavailable",
            "stale_context_explicitly_allowed",
            "external_safe_export_blocked",
            "trivial_task",
            "not_yet_generated",
            "policy_override",
            null
          ]
        },
        "block_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "does_not_establish": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      },
      "required": [
        "schema_version",
        "mode",
        "requires_context",
        "status",
        "has_context_ref",
        "skip_reason",
        "block_reason",
        "does_not_establish"
      ]
    }
  },
  "$id": "https://heimgewebe.local/bureau/execution-envelope.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "baseline_commit": {
      "pattern": "^[0-9a-f]{40}$",
      "type": [
        "string",
        "null"
      ]
    },
    "claims": {
      "type": "array"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "plan": {
      "type": [
        "object",
        "null"
      ]
    },
    "plan_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "rlens_context_ref": {
      "$ref": "#/$defs/rlens_context_ref"
    },
    "run_id": {
      "pattern": "^BUR-RUN-[0-9]{8}T[0-9]{6}Z-[0-9a-f]{10}$",
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "task": {
      "type": "object"
    },
    "task_id": {
      "type": "string"
    },
    "task_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "worker_id": {
      "minLength": 1,
      "type": "string"
    },
    "rlens_context_policy": {
      "$ref": "#/$defs/rlens_policy_evaluation"
    },
    "runtime_truth": {
      "type": "object"
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "task_id",
    "worker_id",
    "task_sha256",
    "plan_sha256",
    "created_at",
    "task",
    "claims"
  ],
  "title": "Bureau execution envelope v1",
  "type": "object"
}
