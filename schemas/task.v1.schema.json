{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heimgewebe.local/bureau/task.v1.schema.json",
  "title": "Bureau task v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "initiative", "title", "state", "execution", "claims", "acceptance"],
  "properties": {
    "schema_version": {"const": 1},
    "id": {"type": "string", "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+$"},
    "initiative": {"type": "string", "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+$"},
    "title": {"type": "string", "minLength": 1},
    "state": {"enum": ["inbox", "planned", "ready", "blocked", "verified", "cancelled", "superseded"]},
    "goal": {"type": "string", "minLength": 1},
    "depends_on": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+$"}},
    "required_capabilities": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "priority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lane", "rank"],
      "properties": {"lane": {"enum": ["now", "next", "later"]}, "rank": {"type": "integer", "minimum": 0}}
    },
    "execution": {
      "type": "object",
      "additionalProperties": true,
      "required": ["mode", "policy"],
      "properties": {
        "mode": {"enum": ["interactive-agent", "grabowski-task", "grabowski-operation", "manual"]},
        "policy": {"enum": ["autonomous", "review-before-effect", "manual", "prohibited"]},
        "preferred_host": {"type": "string", "minLength": 1},
        "working_repository": {"type": "string", "minLength": 1},
        "baseline_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "cwd": {"type": "string", "minLength": 1},
        "argv": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "runtime_seconds": {"type": "integer", "minimum": 1},
        "resume_policy": {"enum": ["never", "retry-safe", "verify-then-retry", "manual"]},
        "cpu_weight": {"type": "integer", "minimum": 1, "maximum": 10000},
        "io_weight": {"type": "integer", "minimum": 1, "maximum": 10000},
        "memory_max_bytes": {"type": "integer", "minimum": 16777216},
        "grabowski_resources": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "operation": {"type": "string", "minLength": 1},
        "operation_parameters": {"type": "object"}
      }
    },
    "claims": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["resource", "mode"],
        "properties": {
          "resource": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{0,254}$"},
          "mode": {"enum": ["read", "write", "exclusive", "capacity"]},
          "amount": {"type": "integer", "minimum": 1},
          "isolation": {"enum": ["none", "worktree", "profile", "display", "namespace"]}
        }
      }
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "assertion"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"},
          "assertion": {"type": "string", "minLength": 1},
          "evidence_type": {"enum": ["object", "string", "boolean", "number", "array"]},
          "verifier": {"type": "string", "minLength": 1}
        }
      }
    },
    "stop": {"type": "object"},
    "rollback": {"type": "object"},
    "metadata": {"type": "object"}
  }
}
