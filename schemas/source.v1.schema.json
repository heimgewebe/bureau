{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heimgewebe.local/bureau/source.v1.schema.json",
  "title": "Bureau source snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source",
    "source_system",
    "repository_path",
    "ref",
    "commit_sha",
    "index_path",
    "schema_path",
    "index_sha256",
    "schema_sha256",
    "source_schema_version",
    "curation",
    "source_files",
    "task_count",
    "status_counts",
    "active_task_ids",
    "entries",
    "does_not_establish"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "source": {"const": "weltgewebe"},
    "source_system": {"const": "weltgewebe-task-control"},
    "repository_path": {"type": "string", "minLength": 1},
    "ref": {"type": "string", "minLength": 1},
    "commit_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "index_path": {"const": "docs/tasks/index.json"},
    "schema_path": {"const": "docs/tasks/schema.json"},
    "index_sha256": {"$ref": "#/$defs/sha256"},
    "schema_sha256": {"$ref": "#/$defs/sha256"},
    "source_schema_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "curation": {"type": "string", "minLength": 1},
    "source_files": {"type": "array", "items": {"type": "string"}},
    "task_count": {"type": "integer", "minimum": 0},
    "status_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["open", "partial", "done", "blocked", "obsolete", "contradicted"],
      "properties": {
        "open": {"type": "integer", "minimum": 0},
        "partial": {"type": "integer", "minimum": 0},
        "done": {"type": "integer", "minimum": 0},
        "blocked": {"type": "integer", "minimum": 0},
        "obsolete": {"type": "integer", "minimum": 0},
        "contradicted": {"type": "integer", "minimum": 0}
      }
    },
    "active_task_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/source_task_id"}
    },
    "entries": {
      "type": "array",
      "items": {"$ref": "#/$defs/entry"}
    },
    "does_not_establish": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_task_id": {"type": "string", "pattern": "^[A-Z]+(?:-[A-Z]+)*-[0-9]{3}$"},
    "count": {"type": "integer", "minimum": 0},
    "link_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issues", "prs", "docs"],
      "properties": {
        "issues": {"$ref": "#/$defs/count"},
        "prs": {"$ref": "#/$defs/count"},
        "docs": {"$ref": "#/$defs/count"}
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "area",
        "status",
        "priority",
        "effort",
        "risk",
        "owner",
        "updated_at",
        "source_task_sha256",
        "evidence_count",
        "missing_evidence_count",
        "acceptance_count",
        "link_counts"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/source_task_id"},
        "title": {"type": "string", "minLength": 1},
        "area": {"enum": ["docs", "ci", "api", "web", "infra", "release", "auth", "map", "governance"]},
        "status": {"enum": ["open", "partial", "done", "blocked", "obsolete", "contradicted"]},
        "priority": {"enum": ["high", "medium", "low"]},
        "effort": {"enum": ["XS", "S", "M", "L", "XL"]},
        "risk": {"enum": ["low", "medium", "high"]},
        "owner": {"type": "string"},
        "updated_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
        "source_task_sha256": {"$ref": "#/$defs/sha256"},
        "evidence_count": {"$ref": "#/$defs/count"},
        "missing_evidence_count": {"$ref": "#/$defs/count"},
        "acceptance_count": {"$ref": "#/$defs/count"},
        "link_counts": {"$ref": "#/$defs/link_counts"}
      }
    }
  }
}
