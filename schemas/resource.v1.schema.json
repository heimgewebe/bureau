{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heimgewebe.local/bureau/resource.v1.schema.json",
  "title": "Bureau resource v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "type"],
  "properties": {
    "schema_version": {"const": 1},
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{0,254}$"},
    "type": {"enum": ["group", "git-repository", "component", "path", "host", "service", "external", "capacity", "failure-domain", "recovery-path"]},
    "parent": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{0,254}$"},
    "capacity": {"type": "integer", "minimum": 1},
    "criticality": {"enum": ["foundational", "essential", "important", "supporting", "optional"]},
    "path": {"type": "string", "minLength": 1},
    "github_slug": {
      "type": "string",
      "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?/[A-Za-z0-9._-]{1,100}$"
    },
    "grabowski_key": {"type": "string", "minLength": 1},
    "metadata": {"type": "object"}
  },
  "allOf": [
    {"if": {"properties": {"type": {"enum": ["capacity", "failure-domain", "recovery-path"]}}, "required": ["type"]}, "then": {"required": ["capacity"]}},
    {"if": {"properties": {"type": {"enum": ["failure-domain", "recovery-path"]}}, "required": ["type"]}, "then": {"required": ["criticality"]}}
  ]
}
