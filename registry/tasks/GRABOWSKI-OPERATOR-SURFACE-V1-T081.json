{
  "acceptance": [
    {
      "assertion": "Jeder Cross-Store-Adapter liest seine Quelle über deren autoritative Read-Oberfläche und hält Audit-, Task-, Lease-, Receipt-, Chronik- und Deployment-Autorität getrennt; die abgeleitete Trace-Projektion erhält keine eigene Entscheidungs- oder Mutationsautorität.",
      "id": "authority-preserving-adapters"
    },
    {
      "assertion": "Jeder externe Trace-Treffer ist an eine konkrete stabile Identität oder einen Digest der jeweiligen Quelle gebunden und lässt sich von der abgeleiteten Korrelation zurück zur autoritativen Evidenz auflösen; ungebundene oder veraltete Quellen werden fail-closed nicht als belegte Verbindung ausgegeben.",
      "id": "digest-bound-cross-store-links"
    },
    {
      "assertion": "Cross-Store-Korrelationen unterscheiden direkte Identitätsbindung, gemeinsame Schlüssel und bloße zeitliche Nähe und behaupten weder Kausalität noch Root Cause, Task-Erfolg oder fachliche Korrektheit ohne separate Evidenz.",
      "id": "no-causality-escalation"
    },
    {
      "assertion": "Alle Adapter und kombinierten Traces besitzen harte Ergebnis- und Payload-Grenzen, validieren Eingaben vor Reads und liefern bei unvollständiger, widersprüchlicher oder nicht verifizierbarer Evidenz strukturierte Lücken statt erfundener Verknüpfungen.",
      "id": "bounded-fail-closed-reads"
    },
    {
      "assertion": "Regressionstests decken positive und negative Bindungen, Digest-/Identitätsdrift, fehlende Quellen, Trunkierung und Nicht-Kausalitätsgrenzen ab; der exakt reviewte Merge wird deployt und an einer realen, verifizierten Audit-Spur mit mindestens zwei getrennten externen Evidenzquellen read-only live belegt.",
      "id": "tests-and-live-proof"
    }
  ],
