{
  "$defs": {
    "rlens_context_ref": {
      "additionalProperties": false,
      "properties": {
        "bundle_commit": {
          "pattern": "^[0-9a-f]{40}$",
          "type": [
            "string",
            "null"
          ]
        },
        "does_not_establish": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "freshness_status": {
          "enum": [
            "fresh_exact",
            "fresh_dirty_unverified",
            "stale_head",
            "unknown",
            "not_required"
          ]
        },
        "generated_at": {
          "format": "date-time",
          "type": "string"
        },
        "live_commit_at_claim": {
          "pattern": "^[0-9a-f]{40}$",
          "type": [
            "string",
            "null"
          ]
        },
        "manifest_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "preflight_status": {
          "enum": [
            "pass",
            "warn",
            "fail",
            "not_applicable",
            "unknown"
          ]
        },
        "repo": {
          "pattern": "^[A-Za-z0-9_.-]{1,120}$",
          "type": "string"
        },
        "schema_version": {
          "const": 1
        },
        "source": {
          "minLength": 1,
          "type": "string"
        },
        "stem": {
          "pattern": "^[A-Za-z0-9_.-]{1,160}$",
          "type": "string"
        },
        "task_profile": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "repo",
        "stem",
        "manifest_sha256",
        "freshness_status",
        "task_profile",
        "preflight_status"
      ],
      "type": "object"
    }
  },
  "$id": "https://heimgewebe.local/bureau/receipt.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "envelope_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "evidence": {
      "minProperties": 1,
      "type": "object"
    },
    "external": {
      "type": [
        "object",
        "null"
      ]
    },
    "plan_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "receipt_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "rlens_context_ref": {
      "$ref": "#/$defs/rlens_context_ref"
    },
    "run_id": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "task_id": {
      "type": "string"
    },
    "task_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "verified_at": {
      "format": "date-time",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "task_id",
    "task_sha256",
    "plan_sha256",
    "envelope_sha256",
    "verified_at",
    "external",
    "evidence",
    "receipt_sha256"
  ],
  "title": "Bureau receipt v1",
  "type": "object"
}
