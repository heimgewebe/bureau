{
  "$defs": {
    "rlens_context_ref": {
      "additionalProperties": false,
      "properties": {
        "bundle_commit": {
          "pattern": "^[0-9a-f]{40}$",
          "type": [
            "string",
            "null"
          ]
        },
        "does_not_establish": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "freshness_status": {
          "enum": [
            "fresh_exact",
            "fresh_dirty_unverified",
            "stale_head",
            "unknown",
            "not_required"
          ]
        },
        "generated_at": {
          "format": "date-time",
          "type": "string"
        },
        "live_commit_at_claim": {
          "pattern": "^[0-9a-f]{40}$",
          "type": [
            "string",
            "null"
          ]
        },
        "manifest_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "preflight_status": {
          "enum": [
            "pass",
            "warn",
            "fail",
            "not_applicable",
            "unknown"
          ]
        },
        "repo": {
          "pattern": "^[A-Za-z0-9_.-]{1,120}$",
          "type": "string"
        },
        "schema_version": {
          "const": 1
        },
        "source": {
          "minLength": 1,
          "type": "string"
        },
        "stem": {
          "pattern": "^[A-Za-z0-9_.-]{1,160}$",
          "type": "string"
        },
        "task_profile": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "repo",
        "stem",
        "manifest_sha256",
        "freshness_status",
        "task_profile",
        "preflight_status"
      ],
      "type": "object"
    },
    "rlens_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "opportunistic",
            "required",
            "strict",
            "live-first",
            "external-safe"
          ]
        },
        "task_profile": {
          "type": "string",
          "minLength": 1
        },
        "skip_reason": {
          "type": "string",
          "enum": [
            "not_required",
            "live_first_primary",
            "context_pack_unavailable",
            "stale_context_explicitly_allowed",
            "external_safe_export_blocked",
            "trivial_task",
            "not_yet_generated",
            "policy_override"
          ]
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "mode"
      ]
    },
    "rlens_policy_evaluation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "opportunistic",
            "required",
            "strict",
            "live-first",
            "external-safe"
          ]
        },
        "requires_context": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "satisfied",
            "skipped",
            "blocked",
            "not_required"
          ]
        },
        "task_profile": {
          "type": [
            "string",
            "null"
          ]
        },
        "has_context_ref": {
          "type": "boolean"
        },
        "skip_reason": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "not_required",
            "live_first_primary",
            "context_pack_unavailable",
            "stale_context_explicitly_allowed",
            "external_safe_export_blocked",
            "trivial_task",
            "not_yet_generated",
            "policy_override",
            null
          ]
        },
        "block_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "does_not_establish": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      },
      "required": [
        "schema_version",
        "mode",
        "requires_context",
        "status",
        "has_context_ref",
        "skip_reason",
        "block_reason",
        "does_not_establish"
      ]
    },
    "coordination_scope_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resource",
        "mode"
      ],
      "properties": {
        "resource": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]{0,254}$"
        },
        "mode": {
          "enum": [
            "capacity",
            "exclusive"
          ]
        },
        "amount": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "coordination_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "base_commit",
        "source_commit",
        "changed_paths",
        "changed_paths_sha256",
        "failure_domains",
        "recovery_paths",
        "does_not_establish",
        "scope_sha256"
      ],
      "properties": {
        "schema_version": {
          "const": 1
        },
        "source_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "changed_paths_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "failure_domains": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/coordination_scope_claim"
          }
        },
        "recovery_paths": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/coordination_scope_claim"
          }
        },
        "does_not_establish": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "scope_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "changed_paths": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5000,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          }
        },
        "base_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        }
      },
      "anyOf": [
        {
          "properties": {
            "failure_domains": {
              "minItems": 1
            }
          }
        },
        {
          "properties": {
            "recovery_paths": {
              "minItems": 1
            }
          }
        }
      ]
    }
  },
  "$id": "https://heimgewebe.local/bureau/task.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "acceptance": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "assertion": {
            "minLength": 1,
            "type": "string"
          },
          "evidence_type": {
            "enum": [
              "object",
              "string",
              "boolean",
              "number",
              "array"
            ]
          },
          "id": {
            "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$",
            "type": "string"
          },
          "verifier": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "id",
          "assertion"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "claims": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "amount": {
            "minimum": 1,
            "type": "integer"
          },
          "isolation": {
            "enum": [
              "none",
              "worktree",
              "profile",
              "display",
              "namespace"
            ]
          },
          "mode": {
            "enum": [
              "read",
              "write",
              "exclusive",
              "capacity"
            ]
          },
          "resource": {
            "pattern": "^[a-z0-9][a-z0-9._:-]{0,254}$",
            "type": "string"
          }
        },
        "required": [
          "resource",
          "mode"
        ],
        "type": "object"
      },
      "type": "array",
      "uniqueItems": true
    },
    "depends_on": {
      "items": {
        "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+$",
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "execution": {
      "additionalProperties": true,
      "properties": {
        "approval": {
          "additionalProperties": false,
          "properties": {
            "action_class": {
              "enum": [
                "agent_dispatch",
                "dry_run",
                "proposal_preview",
                "queue_mutation",
                "read_only_observation",
                "registry_mutation",
                "repository_mutation",
                "runtime_mutation",
                "source_import",
                "state_root_migration",
                "task_creation_from_external_evidence",
                "worktree_cleanup"
              ]
            },
            "note": {
              "minLength": 1,
              "type": "string"
            },
            "required_level": {
              "enum": [
                "none",
                "operator",
                "reviewed_plan",
                "reviewed_receipt",
                "break_glass"
              ]
            }
          },
          "required": [
            "action_class"
          ],
          "type": "object"
        },
        "argv": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "baseline_commit": {
          "pattern": "^[0-9a-f]{40}$",
          "type": "string"
        },
        "cpu_weight": {
          "maximum": 10000,
          "minimum": 1,
          "type": "integer"
        },
        "cwd": {
          "minLength": 1,
          "type": "string"
        },
        "grabowski_resources": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "io_weight": {
          "maximum": 10000,
          "minimum": 1,
          "type": "integer"
        },
        "memory_max_bytes": {
          "minimum": 16777216,
          "type": "integer"
        },
        "mode": {
          "enum": [
            "interactive-agent",
            "grabowski-task",
            "grabowski-operation",
            "manual"
          ]
        },
        "operation": {
          "minLength": 1,
          "type": "string"
        },
        "operation_parameters": {
          "type": "object"
        },
        "policy": {
          "enum": [
            "autonomous",
            "review-before-effect",
            "manual",
            "prohibited"
          ]
        },
        "preferred_host": {
          "minLength": 1,
          "type": "string"
        },
        "resume_policy": {
          "enum": [
            "never",
            "retry-safe",
            "verify-then-retry",
            "manual"
          ]
        },
        "runtime_seconds": {
          "minimum": 1,
          "type": "integer"
        },
        "working_repository": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "mode",
        "policy"
      ],
      "type": "object"
    },
    "goal": {
      "minLength": 1,
      "type": "string"
    },
    "id": {
      "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+$",
      "type": "string"
    },
    "initiative": {
      "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+$",
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "priority": {
      "additionalProperties": false,
      "properties": {
        "lane": {
          "enum": [
            "now",
            "next",
            "later"
          ]
        },
        "rank": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "lane",
        "rank"
      ],
      "type": "object"
    },
    "required_capabilities": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "rlens_context_ref": {
      "$ref": "#/$defs/rlens_context_ref"
    },
    "rollback": {
      "type": "object"
    },
    "schema_version": {
      "const": 1
    },
    "state": {
      "enum": [
        "inbox",
        "planned",
        "ready",
        "blocked",
        "verified",
        "cancelled",
        "superseded"
      ]
    },
    "stop": {
      "type": "object"
    },
    "title": {
      "minLength": 1,
      "type": "string"
    },
    "rlens_policy": {
      "$ref": "#/$defs/rlens_policy"
    },
    "coordination_scope": {
      "$ref": "#/$defs/coordination_scope"
    }
  },
  "required": [
    "schema_version",
    "id",
    "initiative",
    "title",
    "state",
    "execution",
    "claims",
    "acceptance"
  ],
  "title": "Bureau task v1",
  "type": "object"
}
