{
  "$defs": {
    "rlens_context_ref": {
      "additionalProperties": false,
      "properties": {
        "bundle_commit": {
          "pattern": "^[0-9a-f]{40}$",
          "type": [
            "string",
            "null"
          ]
        },
        "does_not_establish": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "freshness_status": {
          "enum": [
            "fresh_exact",
            "fresh_dirty_unverified",
            "stale_head",
            "unknown",
            "not_required"
          ]
        },
        "generated_at": {
          "format": "date-time",
          "type": "string"
        },
        "live_commit_at_claim": {
          "pattern": "^[0-9a-f]{40}$",
          "type": [
            "string",
            "null"
          ]
        },
        "manifest_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "preflight_status": {
          "enum": [
            "pass",
            "warn",
            "fail",
            "not_applicable",
            "unknown"
          ]
        },
        "repo": {
          "pattern": "^[A-Za-z0-9_.-]{1,120}$",
          "type": "string"
        },
        "schema_version": {
          "const": 1
        },
        "source": {
          "minLength": 1,
          "type": "string"
        },
        "stem": {
          "pattern": "^[A-Za-z0-9_.-]{1,160}$",
          "type": "string"
        },
        "task_profile": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "repo",
        "stem",
        "manifest_sha256",
        "freshness_status",
        "task_profile",
        "preflight_status"
      ],
      "type": "object"
    },
    "rlens_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "opportunistic",
            "required",
            "strict",
            "live-first",
            "external-safe"
          ]
        },
        "task_profile": {
          "type": "string",
          "minLength": 1
        },
        "skip_reason": {
          "type": "string",
          "enum": [
            "not_required",
            "live_first_primary",
            "context_pack_unavailable",
            "stale_context_explicitly_allowed",
            "external_safe_export_blocked",
            "trivial_task",
            "not_yet_generated",
            "policy_override"
          ]
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "mode"
      ]
    },
    "rlens_policy_evaluation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "opportunistic",
            "required",
            "strict",
            "live-first",
            "external-safe"
          ]
        },
        "requires_context": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "satisfied",
            "skipped",
            "blocked",
            "not_required"
          ]
        },
        "task_profile": {
          "type": [
            "string",
            "null"
          ]
        },
        "has_context_ref": {
          "type": "boolean"
        },
        "skip_reason": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "not_required",
            "live_first_primary",
            "context_pack_unavailable",
            "stale_context_explicitly_allowed",
            "external_safe_export_blocked",
            "trivial_task",
            "not_yet_generated",
            "policy_override",
            null
          ]
        },
        "block_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "does_not_establish": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      },
      "required": [
        "schema_version",
        "mode",
        "requires_context",
        "status",
        "has_context_ref",
        "skip_reason",
        "block_reason",
        "does_not_establish"
      ]
    },
    "coordination_scope_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resource",
        "mode"
      ],
      "properties": {
        "resource": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]{0,254}$"
        },
        "mode": {
          "enum": [
            "capacity",
            "exclusive"
          ]
        },
        "amount": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "coordination_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "base_commit",
        "source_commit",
        "changed_paths",
        "changed_paths_sha256",
        "failure_domains",
        "recovery_paths",
        "does_not_establish",
        "scope_sha256"
      ],
      "properties": {
        "schema_version": {
          "const": 1
        },
        "source_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "changed_paths_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "failure_domains": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/coordination_scope_claim"
          }
        },
        "recovery_paths": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/coordination_scope_claim"
          }
        },
        "does_not_establish": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "scope_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "changed_paths": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5000,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          }
        },
        "base_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        }
      },
      "anyOf": [
        {
          "properties": {
            "failure_domains": {
              "minItems": 1
            }
          }
        },
        {
          "properties": {
            "recovery_paths": {
              "minItems": 1
            }
          }
        }
      ]
    },
    "coordinated_claim_intent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": 1
        },
        "run_id": {
          "type": "string",
          "pattern": "^BUR-RUN-[0-9]{8}T[0-9]{6}Z-[0-9a-f]{10}$"
        },
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "worker_id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "resource": {
          "type": [
            "string",
            "null"
          ]
        },
        "task_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "plan_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "required_resource_keys": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "lease_owner_id": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at_unix": {
          "type": "integer",
          "minimum": 0
        },
        "workspace": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "repository": {
                  "type": "string",
                  "minLength": 1
                },
                "workspace_path": {
                  "type": "string",
                  "minLength": 1
                },
                "workspace_branch": {
                  "type": "string",
                  "minLength": 1
                },
                "baseline_commit": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{40}$"
                },
                "source_head_at_intent": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{40}$"
                }
              },
              "required": [
                "repository",
                "workspace_path",
                "workspace_branch",
                "baseline_commit",
                "source_head_at_intent"
              ]
            }
          ]
        },
        "operator_approval": {
          "type": "object"
        },
        "runtime_truth_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "does_not_establish": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "intent_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "required": [
        "schema_version",
        "run_id",
        "task_id",
        "worker_id",
        "kind",
        "capabilities",
        "resource",
        "task_sha256",
        "plan_sha256",
        "required_resource_keys",
        "lease_owner_id",
        "created_at",
        "expires_at_unix",
        "workspace",
        "operator_approval",
        "runtime_truth_sha256",
        "does_not_establish",
        "intent_sha256"
      ]
    },
    "coordinated_lease_binding": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "owner_id": {
              "type": "string",
              "minLength": 1
            },
            "task_id": {
              "type": "string",
              "minLength": 1
            },
            "resource_db": {
              "type": "string",
              "minLength": 1
            },
            "resource_db_schema_version": {
              "type": "string",
              "minLength": 1
            },
            "resource_keys": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "min_expires_at_unix": {
              "type": "integer"
            },
            "lease_snapshots": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "observed_at_unix": {
              "type": "integer"
            },
            "minimum_remaining_seconds": {
              "type": "integer",
              "minimum": 30
            },
            "required_metadata_sha256": {
              "type": [
                "string",
                "null"
              ],
              "pattern": "^[0-9a-f]{64}$"
            },
            "lease_binding_sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          },
          "required": [
            "owner_id",
            "task_id",
            "resource_db",
            "resource_db_schema_version",
            "resource_keys",
            "min_expires_at_unix",
            "lease_snapshots",
            "observed_at_unix",
            "minimum_remaining_seconds",
            "required_metadata_sha256",
            "lease_binding_sha256"
          ]
        }
      ]
    }
  },
  "$id": "https://heimgewebe.local/bureau/execution-envelope.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "baseline_commit": {
      "pattern": "^[0-9a-f]{40}$",
      "type": [
        "string",
        "null"
      ]
    },
    "claims": {
      "type": "array"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "plan": {
      "type": [
        "object",
        "null"
      ]
    },
    "plan_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "rlens_context_ref": {
      "$ref": "#/$defs/rlens_context_ref"
    },
    "run_id": {
      "pattern": "^BUR-RUN-[0-9]{8}T[0-9]{6}Z-[0-9a-f]{10}$",
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "task": {
      "type": "object"
    },
    "task_id": {
      "type": "string"
    },
    "task_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "worker_id": {
      "minLength": 1,
      "type": "string"
    },
    "rlens_context_policy": {
      "$ref": "#/$defs/rlens_policy_evaluation"
    },
    "runtime_truth": {
      "type": "object"
    },
    "coordination_scope": {
      "$ref": "#/$defs/coordination_scope"
    },
    "claim_intent": {
      "$ref": "#/$defs/coordinated_claim_intent"
    },
    "lease_binding": {
      "$ref": "#/$defs/coordinated_lease_binding"
    },
    "operator_approval": {
      "type": "object"
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "task_id",
    "worker_id",
    "task_sha256",
    "plan_sha256",
    "created_at",
    "task",
    "claims"
  ],
  "title": "Bureau execution envelope v1",
  "type": "object"
}
