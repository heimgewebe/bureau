{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heimgewebe.local/bureau/execution-envelope.v1.schema.json",
  "title": "Bureau execution envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "task_id", "worker_id", "task_sha256", "plan_sha256", "created_at", "task", "claims"],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string", "pattern": "^BUR-RUN-[0-9]{8}T[0-9]{6}Z-[0-9a-f]{10}$"},
    "task_id": {"type": "string"},
    "worker_id": {"type": "string", "minLength": 1},
    "task_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "plan_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "created_at": {"type": "string", "format": "date-time"},
    "task": {"type": "object"},
    "claims": {"type": "array"},
    "plan": {"type": ["object", "null"]},
    "baseline_commit": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"}
  }
}
