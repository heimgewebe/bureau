  "acceptance": [
    {
      "id": "terminality-and-grace-bound",
      "assertion": "Only valid sources whose final event is agent.run.completed or agent.run.blocked, whose configurable grace period elapsed, and whose file identity remains stable may be selected; active started-only and changing sources remain loose."
    },
    {
      "id": "ledger-and-receipt-bound",
      "assertion": "Compaction requires an intact source/SHA-bound import receipt and exact presence of every source event in the actual Chronik ledger, while receipts remain explicitly nonauthoritative and reconstructible."
    },
    {
      "id": "atomic-replay-bundle",
      "assertion": "Bundle and manifest are immutable, canonical SHA-256-bound, fsynced, fully read back and path-safe before any loose source is removed; partial, orphaned, symlinked or corrupt artifacts fail closed."
    },
    {
      "id": "complete-loss-recovery",
      "assertion": "An isolated empty-ledger and missing-receipt simulation restores all bundled events and recreates receipts from bundle evidence without source loss or divergent event-id acceptance."
    },
    {
      "id": "crash-race-and-rollback-proof",
      "assertion": "Tests cover publish, directory fsync and unlink failures, source mutation before removal, duplicate and conflicting event IDs across loose and bundled sources, repeated apply and relocatable restore."
    },
    {
      "id": "bounded-scale",
      "assertion": "Deterministic benchmarks at live-shaped and 10000-source scale remove the eligible loose files, keep at most one full ledger scan per import and remain below the two-minute timer interval."
    },
    {
      "id": "reviewed-release-and-live-proof",
      "assertion": "The exact reviewed diff passes focused and full tests, role and local smoke gates, GitHub CI, merge-bound deployment, live dry-run, controlled apply, repeated import and ledger-integrity readback with the timer restored."
    },
    {
      "id": "post-bundle-rewrite-guard",
      "assertion": "After a source is manifest-bound and removed, the producer and terminalization paths cannot recreate, truncate or rewrite the same logical source path. A later duplicate must be byte-identical or fail closed into an evidence-preserving quarantine with an explicit receipt."
    }
  ],
  "rollback": {
    "trigger": "Any bundle cannot replay the exact original events, an active or changed source is removed, a partial artifact is accepted, ledger integrity changes unexpectedly, or the importer exceeds the timer safety budget.",
    "procedure": "Stop compaction, retain every bundle and remaining loose source, restore the previous immutable Chronik release, reconstruct removed loose files from manifest-bound bundle byte ranges if needed, run isolated ledger replay and integrity verification, and resume the import timer only after a clean readback."
  },
  "stop": {
    "conditions": [
      "a foreign Chronik worktree, process, task or lease overlaps the selected implementation or live outbox path",
      "the live dry-run reports active, invalid, receiptless, stale-receipt or ledger-unconfirmed sources as eligible",
      "bundle or manifest durability cannot be established before source removal",
      "the empty-ledger recovery simulation or exact event-id/payload comparison fails",
      "the controlled live apply would require deleting a source younger than the approved grace period"
    ]
  },
